{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "CACHE_DIRECTORY": "/tmp"
    }
}

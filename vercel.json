{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|build)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DIRECTORY": "/tmp"
    }
}

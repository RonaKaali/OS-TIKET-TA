{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.7.5" }
    },
    "routes": [
        {
            "src": "/(css|js|images|fonts|build|assets)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://os-tiket-ta.vercel.app",
        "APP_KEY": "base64:Fw9F3mTjBcyJiuB9gVNGYq9LRuNAFb8fJNhy2/RkIVE=",
        "DB_CONNECTION": "mysql"
    }
}
